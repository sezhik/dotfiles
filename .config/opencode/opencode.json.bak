{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin",
  "share": "disabled",
  "provider": {
    "avito": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "avito",
      "options": {
        "baseURL": "https://llm-manager.k.avito.ru/v1",
        "apiKey": "cc375ac0-9dd9-409b-83e0-65d3c845148b",
        "headers": {
          "X-Plugin-Name": "opencode"
        }
      },
      "models": {
        "qwen3-32b": {
          "name": "qwen3-32b (fast)",
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 128000,
          }
        },
        "Qwen/Qwen3-Coder-480B-A35B-Instruct-FP8": {
          "name": "qwen3-coder-480b (strong)",
          "tool_call": true,
          "limit": {
            "context": 256000,
            "output": 256000,
          }
        }
      }
    }
  },
  "mcp": {
    "avito-cli-mcp": {
      "type": "local",
      "command": [
        "avito",
        "mcp"
      ],
      "enabled": true,
      "environment": {
        "HOME": "/Users/sszhikharev"
      }
    }
  }
}
