{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "provider": {
    "avito": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "avito",
      "options": {
        "baseURL": "https://llm-manager.k.avito.ru/v1",
        "apiKey": "cc375ac0-9dd9-409b-83e0-65d3c845148b",
        "headers": {
          "X-Plugin-Name": "opencode"
        }
      },
      "models": {
        "qwen3-32b": {
          "name": "qwen3-32b (fast)",
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 128000
          }
        },
        "minimax-m2": {
          "name": "minimax-m2 (strong)",
          "tool_call": true,
          "limit": {
            "context": 196000,
            "output": 196000
          }
        },
        "Qwen/Qwen3-Coder-480B-A35B-Instruct-FP8": {
          "name": "qwen3-coder-480b (strong)",
          "tool_call": true,
          "limit": {
            "context": 256000,
            "output": 256000
          }
        },
        "openai/gpt-5.1": {
          "name": "openai/gpt-5.1 (strong)",
          "tool_call": true,
          "limit": {
            "context": 512000,
            "output": 512000
          },
          "cost": {
            "input": 1.25,
            "output": 10,
          }
        }
      }
    }
  },
  "mcp": {
    "avito-cli-mcp": {
      "type": "local",
      "command": ["avito", "mcp"],
      "enabled": true,
      "environment": {
        "HOME": "/Users/sszhikharev"
      }
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    }
  }
}
